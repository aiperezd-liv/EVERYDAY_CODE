WITH 
-- 1. SOLIC_CVE DOWNSELL
ids_con_downsell AS (
  SELECT DISTINCT 
    BR_SOLIC_CVE 
  FROM `EIL_DP_VDWH.VFAC_APIS`
  WHERE BR_ORG = 230 
    AND BR_DOWNSELL = 2
    AND BR_CAP_FCH >'2026-01-01'
),

-- 2. CRUCE CON FLUJO 
solicitudes_downsell AS (
  SELECT 
    BR_SOLIC_CVE,
    BR_ORG,
    BR_FLUJO_CVE,
    BR_REGLA_CVE,
    BR_STT_CRED_CVE
  FROM (
    SELECT 
      t2.BR_SOLIC_CVE,
      t2.BR_ORG,
      t2.BR_FLUJO_CVE,
      t2.BR_REGLA_CVE,
      t2.BR_STT_CRED_CVE,
      -- ODERNADO DE FLUJO 
      ROW_NUMBER() OVER(PARTITION BY t2.BR_SOLIC_CVE ORDER BY t2.BR_FLUJO_CVE DESC) AS rn
    FROM `EIL_DP_VDWH.VFAC_OMDM_FLUJO` t2
    INNER JOIN ids_con_downsell t1
      ON t2.BR_SOLIC_CVE = t1.BR_SOLIC_CVE
    -- FILTRO DOWNSELL TD
    WHERE t2.BR_ORG = 210
  )
  -- FILTRO DE ULTIMO FLUJO 
  WHERE rn = 1
)

-- 3. CONTEO DE REGLAS 
SELECT 
  BR_REGLA_CVE,
  COUNT(*) AS conteo
FROM solicitudes_downsell
GROUP BY BR_REGLA_CVE
ORDER BY BR_REGLA_CVE DESC;
